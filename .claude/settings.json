{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "python3 scripts/update_changelog.py",
            "timeout": 10,
            "statusMessage": "Updating changelog..."
          }
        ]
      }
    ]
  }
}
